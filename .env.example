# Todas las variables expuestas al cliente DEBEN empezar con VITE_
 

# Ruta relativa e interceptada por Mock Service Worker (MSW) en el navegador.
# Al apuntar a un backend real, solo cambia este valor por una URL absoluta
# (ej. https://api.miempresa.com) — ningún componente necesita modificarse.
VITE_API_BASE_URL=/api
=======
VITE_API_BASE_URL=https://api.example.com
VITE_APP_ENV=development
